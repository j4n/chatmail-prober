{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "table", "name": "Table" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "esnet-matrix-panel", "name": "ESnet Matrix" }
  ],
  "id": null,
  "uid": "chatmail-inter",
  "title": "Chatmail Relay Interop — Cross-relay",
  "description": "Interoperability probe results between relay pairs",
  "tags": ["chatmail", "cmping", "interop"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-2h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "source",
        "label": "From relay",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_success, source)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "destination",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_success, destination)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Pairs OK / Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_success == 1) / count(cmping_probe_success)",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "title": "Total Pairs Monitored",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_success)",
          "legendFormat": "pairs"
        }
      ]
    },
    {
      "title": "Failed Pairs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_success == 0) or vector(0)",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "title": "Median RTT (all pairs)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(cmping_response_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "title": "RTT Matrix",
      "description": "Avg RTT per (source, destination) pair. Green = fast, yellow = >1s, red = >10s. Failed pairs show no data (red null color).",
      "type": "esnet-matrix-panel",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 32, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "orange", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "sourceField": "destination",
        "targetField": "source",
        "valueField": "Value",
        "cellSize": 24,
        "cellPadding": 2,
        "txtLength": 20,
        "txtSize": 12,
        "nullColor": "#d44a3a",
        "defaultColor": "#d44a3a"
      },
      "targets": [
        {
          "expr": "cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"} / cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Probe Results",
      "description": "All pairs sorted by source. Quantiles use cumulative histogram (no rate needed — works for single-round runs too).",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "destination" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "OK" },
            "properties": [
              { "id": "custom.width", "value": 55 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^(Avg|p50|p90|p99)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 80 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "orange", "value": 10 },
                    { "color": "red", "value": 15 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "source", "desc": false }]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_probe_success{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"} / cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.50, sum by (le, source, destination) (cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.90, sum by (le, source, destination) (cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "histogram_quantile(0.99, sum by (le, source, destination) (cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true,
              "Time 4": true, "Time 5": true,
              "__name__": true, "instance": true, "job": true
            },
            "renameByName": {
              "Value #A": "OK",
              "Value #B": "Avg",
              "Value #C": "p50",
              "Value #D": "p90",
              "Value #E": "p99"
            },
            "indexByName": {
              "source": 0,
              "destination": 1,
              "OK": 2,
              "Avg": 3,
              "p50": 4,
              "p90": 5,
              "p99": 6
            }
          }
        }
      ]
    },
    {
      "title": "Probe Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "collapsed": false
    },
    {
      "title": "Failing Pairs Timeline",
      "description": "Shows only failing pairs (probe_success=0). States are extended across gaps between probe rounds.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 54 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } }
          ],
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "showValue": "auto",
        "alignValue": "center",
        "mergeValues": true,
        "rowHeight": 0.8
      },
      "targets": [
        {
          "expr": "cmping_probe_success{source=~\"$source\", destination=~\"$destination\"} == 0",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 64 },
      "collapsed": false
    },
    {
      "title": "RTT Quantiles — $source -> $destination",
      "description": "Smokeping-style latency bands: p10, p50, p90, p99. Select specific source/destination from the dropdowns above.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 65 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "drawStyle": "line",
            "gradientMode": "scheme",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, source, destination) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p99 {{source}} -> {{destination}}"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le, source, destination) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p90 {{source}} -> {{destination}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, source, destination) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p50 {{source}} -> {{destination}}"
        },
        {
          "expr": "histogram_quantile(0.10, sum by (le, source, destination) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p10 {{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Per-Pair Average RTT",
      "description": "Average round-trip time per relay pair over time.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "rate(cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval]) / rate(cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Errors & Setup",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 85 },
      "collapsed": false
    },
    {
      "title": "Send Errors (cumulative)",
      "description": "Pairs that have accumulated send errors. Shows total error count per pair.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 86 },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true, "displayMode": "color-background-solid" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "destination" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Errors", "desc": true }]
      },
      "targets": [
        {
          "expr": "cmping_send_errors_total{source=~\"$source\", destination=~\"$destination\"} > 0",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": { "Value": "Errors" }
          }
        }
      ]
    },
    {
      "title": "Account Setup Time",
      "description": "Time spent setting up accounts on each relay pair. High on first run, near-zero on subsequent runs.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 86 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_account_setup_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
