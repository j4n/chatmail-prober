{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "table", "name": "Table" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "esnet-matrix-panel", "name": "ESnet Matrix" }
  ],
  "id": null,
  "uid": "chatmail-inter",
  "title": "Chatmail Relay Interop — Cross-relay",
  "description": "Interoperability probe results between relay pairs",
  "tags": ["chatmail"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-2h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "source",
        "label": "From relay",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_loss_ratio{probe_type=\"cross\"}, source)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "destination",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_loss_ratio{probe_type=\"cross\"}, destination)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Pairs OK / Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_loss_ratio{probe_type=\"cross\"} == 0) / count(cmping_probe_loss_ratio{probe_type=\"cross\"})",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "title": "Total Pairs Monitored",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_loss_ratio{probe_type=\"cross\"})",
          "legendFormat": "pairs"
        }
      ]
    },
    {
      "title": "Failed Pairs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_loss_ratio{probe_type=\"cross\"} > 0) or vector(0)",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "title": "Median RTT (all pairs)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "avg(cmping_rtt_median_seconds{probe_type=\"cross\"})",
          "legendFormat": "median"
        }
      ]
    },
    {
      "title": "RTT Matrix",
      "description": "Median RTT per (source, destination) pair. Green = fast, yellow = >2s, red = >10s. Failed pairs show no data (red null color).",
      "type": "esnet-matrix-panel",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 24, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "orange", "value": 10 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          }
        ]
      },
      "options": {
        "sourceField": "destination",
        "targetField": "source",
        "valueField": "Value",
        "cellSize": 18,
        "cellPadding": 1,
        "txtLength": 14,
        "txtSize": 10,
        "nullColor": "#d44a3a",
        "defaultColor": "#d44a3a",
        "extraTooltipFields": "Loss,p10,p90"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_rtt_median_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "cmping_probe_loss_ratio{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "cmping_rtt_p10_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "cmping_rtt_p90_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Probe Results",
      "description": "All cross-relay pairs with current probe status, median RTT, and p90 RTT.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 24, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          },
          {
            "matcher": { "id": "byName", "options": "destination" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          },
          {
            "matcher": { "id": "byName", "options": "OK" },
            "properties": [
              { "id": "custom.width", "value": 55 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^(Median|p90)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 80 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "orange", "value": 10 },
                    { "color": "red", "value": 15 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "source", "desc": false }]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_probe_loss_ratio{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "cmping_rtt_median_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "cmping_rtt_p90_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true,
              "__name__": true, "instance": true, "job": true,
              "probe_type": true
            },
            "renameByName": {
              "Value #A": "Loss",
              "Value #B": "Median",
              "Value #C": "p90"
            },
            "indexByName": {
              "source": 0,
              "destination": 1,
              "Loss": 2,
              "Median": 3,
              "p90": 4
            }
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "source": { "aggregations": [], "operation": "groupby" },
              "destination": { "aggregations": [], "operation": "groupby" },
              "Loss": { "aggregations": ["lastNotNull"], "operation": "aggregate" },
              "Median": { "aggregations": ["lastNotNull"], "operation": "aggregate" },
              "p90": { "aggregations": ["lastNotNull"], "operation": "aggregate" }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Loss (lastNotNull)": "Loss",
              "Median (lastNotNull)": "Median",
              "p90 (lastNotNull)": "p90"
            }
          }
        }
      ]
    },
    {
      "title": "Probe Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false
    },
    {
      "title": "Pairs with Loss",
      "description": "Shows only pairs with packet loss (loss_ratio > 0). Color indicates severity.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "#ff6600", "value": 0.5 },
              { "color": "red", "value": 0.7 },
              { "color": "dark-red", "value": 0.9 }
            ]
          },
          "mappings": [
            { "type": "value", "options": {
              "0.2": { "text": "1 lost", "color": "yellow" },
              "0.4": { "text": "2 lost", "color": "orange" },
              "0.6": { "text": "3 lost", "color": "#ff6600" },
              "0.8": { "text": "4 lost", "color": "red" },
              "1":   { "text": "FAIL",   "color": "dark-red" }
            } }
          ],
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "showValue": "auto",
        "alignValue": "center",
        "mergeValues": true,
        "rowHeight": 0.8
      },
      "targets": [
        {
          "expr": "cmping_probe_loss_ratio{source=~\"$source\", destination=~\"$destination\"} > 0",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },
    {
      "title": "Median RTT",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true,
            "scaleDistribution": { "type": "log", "log": 10 }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_rtt_median_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "p90 RTT",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 51 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true,
            "scaleDistribution": { "type": "log", "log": 10 }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_rtt_p90_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Stddev",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 61 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true,
            "scaleDistribution": { "type": "log", "log": 10 }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_rtt_stddev_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Errors & Setup",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 71 },
      "collapsed": false
    },
    {
      "title": "Send Errors (cumulative)",
      "description": "Pairs that have accumulated send errors. Shows total error count per pair.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 72 },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true, "displayMode": "color-background-solid" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          },
          {
            "matcher": { "id": "byName", "options": "destination" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Errors", "desc": true }]
      },
      "targets": [
        {
          "expr": "cmping_send_errors_total{source=~\"$source\", destination=~\"$destination\"} > 0",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "__name__": true, "instance": true, "job": true,
              "probe_type": true
            },
            "renameByName": { "Value": "Errors" }
          }
        }
      ]
    },
    {
      "title": "Account Setup Time",
      "description": "Time spent setting up accounts on each relay pair. High on first run, near-zero on subsequent runs.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 72 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_account_setup_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
