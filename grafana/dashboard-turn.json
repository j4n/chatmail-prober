{
  "title": "Chatmail TURN + iroh health",
  "uid": "chatmail-turn",
  "tags": [
    "chatmail",
    "turn",
    "iroh"
  ],
  "schemaVersion": 39,
  "timezone": "",
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "relay",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values({__name__=~\"cmping_relay_(turn|iroh)_status\"}, relay)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "TURN",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "title": "TURN availability",
      "description": "Per-relay TURN endpoint health. 1=ok, 0=down, -2=parse-err, -4=no-binary, -5=timeout.",
      "type": "state-timeline",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 18,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ok",
                  "color": "green"
                },
                "0": {
                  "text": "down",
                  "color": "red"
                },
                "-2": {
                  "text": "parse-err",
                  "color": "orange"
                },
                "-4": {
                  "text": "no-binary",
                  "color": "purple"
                },
                "-5": {
                  "text": "timeout",
                  "color": "yellow"
                }
              }
            }
          ]
        }
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_status",
          "legendFormat": "{{relay}} ({{turn_endpoint}})"
        }
      ]
    },
    {
      "title": "TURN breakdown",
      "description": "Relays grouped by TURN endpoint kind (self-published vs fallback turn.delta.chat) and health.",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 18,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "self ok"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "self failing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "fallback ok"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "fallback failing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "pie",
        "displayLabels": [
          "value"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(cmping_relay_turn_status{turn_endpoint=\"self\"} == 1)",
          "legendFormat": "self ok",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "count(cmping_relay_turn_status{turn_endpoint=\"self\"} != 1)",
          "legendFormat": "self failing",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "count(cmping_relay_turn_status{turn_endpoint=\"fallback\"} == 1)",
          "legendFormat": "fallback ok",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "count(cmping_relay_turn_status{turn_endpoint=\"fallback\"} != 1)",
          "legendFormat": "fallback failing",
          "instant": true
        }
      ]
    },
    {
      "title": "TURN failing right now",
      "description": "Relays whose latest TURN probe is not OK, including which endpoint kind (self vs fallback) was tested. Empty = all healthy.",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 18,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ok",
                  "color": "green"
                },
                "0": {
                  "text": "down",
                  "color": "red"
                },
                "-2": {
                  "text": "parse-err",
                  "color": "orange"
                },
                "-4": {
                  "text": "no-binary",
                  "color": "purple"
                },
                "-5": {
                  "text": "timeout",
                  "color": "yellow"
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "displayName",
                "value": "status"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "relay",
            "desc": false
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_status != 1",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "relay",
                "turn_endpoint",
                "Value"
              ]
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "TURN timing",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "panels": []
    },
    {
      "title": "Connect time (TURN allocate)",
      "description": "Time to establish the TURN allocation, per relay, Loopback measurement. ",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_connect_seconds",
          "legendFormat": "{{relay}} ({{turn_endpoint}})"
        }
      ]
    },
    {
      "title": "Transmit time",
      "description": "Total loopback test transmit duration. ",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_transmit_seconds",
          "legendFormat": "{{relay}} ({{turn_endpoint}})"
        }
      ]
    },
    {
      "type": "row",
      "title": "iroh",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "panels": []
    },
    {
      "title": "iroh availability",
      "description": "Per-relay iroh-relay HTTP health. 1=ok, 0=down, -2=no-metadata, -3=imap-failed, -5=timeout.",
      "type": "state-timeline",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 18,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ok",
                  "color": "green"
                },
                "0": {
                  "text": "down",
                  "color": "red"
                },
                "-2": {
                  "text": "no-metadata",
                  "color": "orange"
                },
                "-3": {
                  "text": "imap-failed",
                  "color": "purple"
                },
                "-5": {
                  "text": "timeout",
                  "color": "yellow"
                }
              }
            }
          ]
        }
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_iroh_status",
          "legendFormat": "{{relay}}"
        }
      ]
    },
    {
      "title": "iroh breakdown",
      "description": "Relays grouped by iroh-relay status. no-metadata = server doesn't advertise an iroh URL; imap-failed = could not fetch metadata.",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 18,
        "w": 6,
        "x": 12,
        "y": 29
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ok"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "down"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "no-metadata"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "imap-failed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "timeout"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "pie",
        "displayLabels": [
          "value"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false,
          "fields": ""
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(cmping_relay_iroh_status == 1)",
          "legendFormat": "ok",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "count(cmping_relay_iroh_status == 0)",
          "legendFormat": "down",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "count(cmping_relay_iroh_status == -2)",
          "legendFormat": "no-metadata",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "count(cmping_relay_iroh_status == -3)",
          "legendFormat": "imap-failed",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "count(cmping_relay_iroh_status == -5)",
          "legendFormat": "timeout",
          "instant": true
        }
      ]
    },
    {
      "title": "iroh failing right now",
      "description": "Relays whose latest iroh-relay probe is not OK. Empty = all healthy.",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 18,
        "w": 6,
        "x": 18,
        "y": 29
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ok",
                  "color": "green"
                },
                "0": {
                  "text": "down",
                  "color": "red"
                },
                "-2": {
                  "text": "no-metadata",
                  "color": "orange"
                },
                "-3": {
                  "text": "imap-failed",
                  "color": "purple"
                },
                "-5": {
                  "text": "timeout",
                  "color": "yellow"
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "displayName",
                "value": "status"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "relay",
            "desc": false
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_iroh_status != 1",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "relay",
                "Value"
              ]
            }
          }
        }
      ]
    },
    {
      "title": "iroh latency (per relay)",
      "description": "Last iroh-relay HTTP probe latency. One sample per round (~15 min cadence). Log y-axis.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 47
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true,
            "scaleDistribution": {
              "type": "log",
              "log": 10
            }
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_iroh_latency_seconds",
          "legendFormat": "{{relay}}"
        }
      ]
    }
  ]
}
