{
  "title": "Chatmail TURN health",
  "uid": "chatmail-turn",
  "tags": [
    "chatmail",
    "turn"
  ],
  "schemaVersion": 39,
  "timezone": "",
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "relay",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(cmping_relay_turn_status, relay)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "title": "TURN availability",
      "description": "Per-relay TURN endpoint health. 1=ok, 0=down, -2=parse-err, -4=no-binary, -5=timeout.",
      "type": "state-timeline",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ok",
                  "color": "green"
                },
                "0": {
                  "text": "down",
                  "color": "red"
                },
                "-2": {
                  "text": "parse-err",
                  "color": "orange"
                },
                "-4": {
                  "text": "no-binary",
                  "color": "purple"
                },
                "-5": {
                  "text": "timeout",
                  "color": "yellow"
                }
              }
            }
          ]
        }
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "alignValue": "left",
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_status",
          "legendFormat": "{{relay}} ({{turn_endpoint}})"
        }
      ]
    },
    {
      "title": "Endpoint type",
      "description": "Relays publishing their own TURN vs falling back to turn.delta.chat. A sudden swing to fallback means relays stopped publishing IMAP METADATA.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count by (turn_endpoint) (cmping_relay_turn_status == 1)",
          "legendFormat": "{{turn_endpoint}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Per-relay TURN smokeping",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "title": "TURN RTT -- $relay",
      "description": "Smokeping-style: avg line with min-max band.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0,
            "drawStyle": "line",
            "spanNulls": true,
            "scaleDistribution": {
              "type": "log",
              "log": 10
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "dark-green",
                "value": null
              },
              {
                "color": "green",
                "value": 2
              },
              {
                "color": "light-green",
                "value": 6
              },
              {
                "color": "yellow",
                "value": 24
              },
              {
                "color": "red",
                "value": 48
              },
              {
                "color": "dark-red",
                "value": 60
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "max"
            },
            "properties": [
              {
                "id": "custom.fillBelowTo",
                "value": "min"
              },
              {
                "id": "custom.fillOpacity",
                "value": 15
              },
              {
                "id": "custom.lineWidth",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#cccccc"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "min"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#cccccc"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.gradientMode",
                "value": "scheme"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "dark-green",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 2
                    },
                    {
                      "color": "light-green",
                      "value": 6
                    },
                    {
                      "color": "yellow",
                      "value": 24
                    },
                    {
                      "color": "red",
                      "value": 48
                    },
                    {
                      "color": "dark-red",
                      "value": 60
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_rtt_seconds{relay=\"$relay\", quantile=\"max\"}",
          "legendFormat": "max"
        },
        {
          "refId": "B",
          "expr": "cmping_relay_turn_rtt_seconds{relay=\"$relay\", quantile=\"avg\"}",
          "legendFormat": "avg"
        },
        {
          "refId": "C",
          "expr": "cmping_relay_turn_rtt_seconds{relay=\"$relay\", quantile=\"min\"}",
          "legendFormat": "min"
        }
      ],
      "repeat": "relay",
      "repeatDirection": "h"
    },
    {
      "title": "TURN Jitter -- $relay",
      "description": "Smokeping-style: avg line with min-max band.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0,
            "drawStyle": "line",
            "spanNulls": true,
            "scaleDistribution": {
              "type": "log",
              "log": 10
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "dark-green",
                "value": null
              },
              {
                "color": "green",
                "value": 2
              },
              {
                "color": "light-green",
                "value": 6
              },
              {
                "color": "yellow",
                "value": 24
              },
              {
                "color": "red",
                "value": 48
              },
              {
                "color": "dark-red",
                "value": 60
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "max"
            },
            "properties": [
              {
                "id": "custom.fillBelowTo",
                "value": "min"
              },
              {
                "id": "custom.fillOpacity",
                "value": 15
              },
              {
                "id": "custom.lineWidth",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#cccccc"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "min"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#cccccc"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "custom.gradientMode",
                "value": "scheme"
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "dark-green",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 2
                    },
                    {
                      "color": "light-green",
                      "value": 6
                    },
                    {
                      "color": "yellow",
                      "value": 24
                    },
                    {
                      "color": "red",
                      "value": 48
                    },
                    {
                      "color": "dark-red",
                      "value": 60
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_jitter_seconds{relay=\"$relay\", quantile=\"max\"}",
          "legendFormat": "max"
        },
        {
          "refId": "B",
          "expr": "cmping_relay_turn_jitter_seconds{relay=\"$relay\", quantile=\"avg\"}",
          "legendFormat": "avg"
        },
        {
          "refId": "C",
          "expr": "cmping_relay_turn_jitter_seconds{relay=\"$relay\", quantile=\"min\"}",
          "legendFormat": "min"
        }
      ]
    },
    {
      "type": "row",
      "title": "Loss / connect timing",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "panels": []
    },
    {
      "title": "Lost packets",
      "description": "Packets lost during the loopback test, per relay.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_lost_packets",
          "legendFormat": "{{relay}} ({{turn_endpoint}})"
        }
      ]
    },
    {
      "title": "Send dropped",
      "description": "Packets dropped on send, per relay.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_send_dropped",
          "legendFormat": "{{relay}} ({{turn_endpoint}})"
        }
      ]
    },
    {
      "title": "Connect time",
      "description": "TURN allocate latency, per relay.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 21
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_connect_seconds",
          "legendFormat": "{{relay}} ({{turn_endpoint}})"
        }
      ]
    },
    {
      "type": "row",
      "title": "Fallback comparison",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "panels": []
    },
    {
      "title": "Fallback avg RTT (per relay)",
      "description": "All relays hitting turn.delta.chat should overlap. A divergent line means that relay's outbound path is degraded even though the TURN server itself is fine.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_relay_turn_rtt_seconds{turn_endpoint=\"fallback\", quantile=\"avg\"}",
          "legendFormat": "{{relay}}"
        }
      ]
    }
  ]
}
