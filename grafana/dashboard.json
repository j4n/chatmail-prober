        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "expr": "count(count by (source) (max_over_time(cmping_probe_success[$__rate_interval]) == 0) unless on(source) count by (source) (max_over_time(cmping_probe_success[$__rate_interval]) > 0)) or vector(0)",
          "legendFormat": "dead",
          "refId": "A"
        }
      ],
      "title": "Dead Relays",
      "type": "stat"
    },
    {
      "datasource": {
