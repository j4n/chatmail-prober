        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "Value": "avg_rtt",
              "Value #avg_rtt": "avg_rtt",
              "Value #probe_success": "probe_success"
            }
          }
        }
      ],
      "type": "table"
