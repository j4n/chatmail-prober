      "targets": [
        {
          "expr": "rate(cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval]) / rate(cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])",
