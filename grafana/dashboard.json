{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "table", "name": "Table" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" }
  ],
  "id": null,
  "uid": "chatmail-prober",
  "title": "Chatmail Relay Interop",
  "description": "Smokeping-style interoperability monitoring for chatmail relays",
  "tags": ["chatmail", "cmping", "interop"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_success, source)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "destination",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_success, destination)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Pairs OK / Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_success == 1) / count(cmping_probe_success)",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "title": "Total Pairs Monitored",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_success)",
          "legendFormat": "pairs"
        }
      ]
    },
    {
      "title": "Failed Pairs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_success == 0) or vector(0)",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "title": "Median RTT (all pairs)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(cmping_response_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "title": "Status Matrix — Avg RTT (seconds)",
      "description": "Source (rows) → Destination (columns). Green = OK, Red = failed. Value = average RTT in seconds over the selected time range.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#73BF69", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "custom": {
            "displayMode": "color-background-solid",
            "align": "center",
            "inspect": false,
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "custom.displayMode", "value": "auto" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "source", "desc": false }]
      },
      "targets": [
        {
          "expr": "rate(cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval]) / rate(cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])",
          "legendFormat": "{{source}} → {{destination}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {}
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "source": { "aggregations": [], "operation": "groupby" },
              "destination": { "aggregations": [], "operation": "groupby" },
              "Value": { "aggregations": ["lastNotNull"], "operation": "aggregate" }
            }
          }
        },
        {
          "id": "rowsToFields",
          "options": { "mappings": [{ "fieldName": "destination", "handlerKey": "field.name" }] }
        }
      ]
    },
    {
      "title": "Probe Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "title": "Probe Success Timeline",
      "description": "Green = success (all pings received), Red = failure. Shows outage windows per relay pair.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } }
          ],
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "showValue": "auto",
        "alignValue": "center",
        "mergeValues": true,
        "rowHeight": 0.8
      },
      "targets": [
        {
          "expr": "cmping_probe_success{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} → {{destination}}"
        }
      ]
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false
    },
    {
      "title": "RTT Quantiles — $source → $destination",
      "description": "Smokeping-style latency bands: p10, p50, p90, p99. Select specific source/destination from the dropdowns above.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "drawStyle": "line",
            "gradientMode": "scheme",
            "spanNulls": false,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.10, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p10"
        }
      ]
    },
    {
      "title": "Per-Pair Average RTT",
      "description": "Average round-trip time per relay pair over time.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 39 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "rate(cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval]) / rate(cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])",
          "legendFormat": "{{source}} → {{destination}}"
        }
      ]
    },
    {
      "title": "Errors & Setup",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "title": "Send Errors Rate",
      "description": "Rate of failed probe rounds per relay pair.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1,
            "drawStyle": "bars",
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(cmping_send_errors_total{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval]) > 0",
          "legendFormat": "{{source}} → {{destination}}"
        }
      ]
    },
    {
      "title": "Account Setup Time",
      "description": "Time spent setting up accounts on each relay pair. High on first run, low on subsequent runs.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_account_setup_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} → {{destination}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
