          "legendFormat": "avg_rtt",
          "refId": "A"
        },
        {
          "expr": "cmping_probe_success{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "probe_success",
          "refId": "B"
        }
      ],
