{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "table", "name": "Table" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" }
  ],
  "id": null,
  "uid": "chatmail-prober",
  "title": "Chatmail Relay Interop",
  "description": "Smokeping-style interoperability monitoring for chatmail relays",
  "tags": ["chatmail", "cmping", "interop"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-2h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "source",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_loss_ratio, source)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "destination",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_loss_ratio, destination)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "relay",
        "label": "Relay (self-probe)",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_loss_ratio, source)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Pairs OK / Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_loss_ratio == 0) / count(cmping_probe_loss_ratio)",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "title": "Total Pairs Monitored",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_loss_ratio)",
          "legendFormat": "pairs"
        }
      ]
    },
    {
      "title": "Failed Pairs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_loss_ratio > 0) or vector(0)",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "title": "Dead Relays",
      "description": "Relays that failed the alive check and are excluded from the matrix.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(count by (source) (min_over_time(cmping_probe_loss_ratio[$__rate_interval]) > 0)) or vector(0)",
          "legendFormat": "dead"
        }
      ]
    },
    {
      "title": "Median RTT (all pairs)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(cmping_response_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "title": "Probe Results — Avg RTT",
      "description": "All (source, destination) pairs. Avg RTT = lifetime average (sum/count). Green < 5s, yellow < 10s, red >= 15s. Filter with source/destination variables above.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "destination" },
            "properties": [{ "id": "custom.width", "value": 220 }]
          },
          {
            "matcher": { "id": "byName", "options": "Avg RTT" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 5 },
                    { "color": "orange", "value": 10 },
                    { "color": "red", "value": 15 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Loss" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.1 },
                    { "color": "orange", "value": 0.3 },
                    { "color": "red", "value": 0.7 },
                    { "color": "dark-red", "value": 0.9 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Avg RTT", "desc": false }]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"} / cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "cmping_probe_loss_ratio{source=~\"$source\", destination=~\"$destination\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true,
              "__name__": true, "instance": true, "job": true
            },
            "renameByName": {
              "Value #A": "Avg RTT",
              "Value #B": "Loss"
            }
          }
        }
      ]
    },
    {
      "title": "Probe Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false
    },
    {
      "title": "Pairs with Loss",
      "description": "Shows only pairs with packet loss (loss_ratio > 0). Color indicates severity.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "#ff6600", "value": 0.5 },
              { "color": "red", "value": 0.7 },
              { "color": "dark-red", "value": 0.9 }
            ]
          },
          "mappings": [
            { "type": "value", "options": {
              "0.2": { "text": "1 lost", "color": "yellow" },
              "0.4": { "text": "2 lost", "color": "orange" },
              "0.6": { "text": "3 lost", "color": "#ff6600" },
              "0.8": { "text": "4 lost", "color": "red" },
              "1":   { "text": "FAIL",   "color": "dark-red" }
            } }
          ],
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "showValue": "auto",
        "alignValue": "center",
        "mergeValues": true,
        "rowHeight": 0.8
      },
      "targets": [
        {
          "expr": "cmping_probe_loss_ratio{source=~\"$source\", destination=~\"$destination\"} > 0",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false
    },
    {
      "title": "Self-probe RTT — $relay",
      "description": "Smokeping-style RTT for a single relay probing itself (source=destination=$relay). Select a relay from the top-right dropdown. Shows per-relay delivery latency independent of cross-relay variation.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "drawStyle": "line",
            "gradientMode": "scheme",
            "spanNulls": false,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$relay\", destination=~\"$relay\"}[$__rate_interval])))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$relay\", destination=~\"$relay\"}[$__rate_interval])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$relay\", destination=~\"$relay\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.10, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$relay\", destination=~\"$relay\"}[$__rate_interval])))",
          "legendFormat": "p10"
        }
      ]
    },
    {
      "title": "RTT Quantiles — $source -> $destination",
      "description": "Smokeping-style latency bands: p10, p50, p90, p99. Select specific source/destination from the dropdowns above.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "drawStyle": "line",
            "gradientMode": "scheme",
            "spanNulls": false,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.10, sum by (le) (rate(cmping_response_duration_seconds_bucket{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])))",
          "legendFormat": "p10"
        }
      ]
    },
    {
      "title": "Per-Pair Average RTT",
      "description": "Average round-trip time per relay pair over time.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 51 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "rate(cmping_response_duration_seconds_sum{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval]) / rate(cmping_response_duration_seconds_count{source=~\"$source\", destination=~\"$destination\"}[$__rate_interval])",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    },
    {
      "title": "Errors & Setup",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 61 },
      "collapsed": false
    },
    {
      "title": "Send Errors (cumulative)",
      "description": "Pairs that have accumulated send errors (probe round failures). Shows total error count, not rate — useful for both one-shot and continuous runs.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true, "displayMode": "color-background-solid" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "destination" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "expr": "cmping_send_errors_total{source=~\"$source\", destination=~\"$destination\"} > 0",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": { "Value": "Errors" }
          }
        }
      ]
    },
    {
      "title": "Account Setup Time",
      "description": "Time spent setting up accounts on each relay pair. High on first run, low on subsequent runs.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 62 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_account_setup_seconds{source=~\"$source\", destination=~\"$destination\"}",
          "legendFormat": "{{source}} -> {{destination}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 3
}
