{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "table", "name": "Table" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" }
  ],
  "id": null,
  "uid": "chatmail-intra",
  "title": "Chatmail Relay Interop — Self-probe",
  "description": "Per-relay self-probe health: each relay sends a message to itself to measure local delivery latency",
  "tags": ["chatmail", "cmping", "interop"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5m",
  "time": { "from": "now-2h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "relay",
        "label": "Relay",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(cmping_probe_success{probe_type=\"self\"}, source)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Relays Monitored",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(count by (source) (cmping_probe_success{source=~\"$relay\", probe_type=\"self\"}))",
          "legendFormat": "relays"
        }
      ]
    },
    {
      "title": "Dead Relays",
      "description": "Relays with no successful self-probe in the current scrape window.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(cmping_probe_success{source=~\"$relay\", probe_type=\"self\"} == 0) or vector(0)",
          "legendFormat": "dead"
        }
      ]
    },
    {
      "title": "Median Self-probe RTT",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "avg(cmping_rtt_median_seconds{source=~\"$relay\", probe_type=\"self\"})",
          "legendFormat": "median"
        }
      ]
    },
    {
      "title": "Self-probe RTT per Relay",
      "description": "Current median RTT and probe status for each relay's self-probe.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "custom": { "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [
              { "id": "displayName", "value": "Relay" },
              { "id": "custom.width", "value": 260 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Median RTT" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 2 },
                    { "color": "orange", "value": 5 },
                    { "color": "red", "value": 10 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "OK" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Median RTT", "desc": false }]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "cmping_rtt_median_seconds{source=~\"$relay\", probe_type=\"self\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "cmping_probe_success{source=~\"$relay\", probe_type=\"self\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true,
              "__name__": true, "instance": true, "job": true,
              "destination": true, "probe_type": true
            },
            "renameByName": {
              "Value #A": "Median RTT",
              "Value #B": "OK"
            }
          }
        }
      ]
    },
    {
      "title": "Relay Health Timeline",
      "description": "One row per relay. Self-probe success (green) or failure (red) over time. States are extended across gaps between probe rounds.",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "OK", "color": "green" } } }
          ],
          "custom": {
            "fillOpacity": 80,
            "spanNulls": true
          }
        }
      },
      "options": {
        "showValue": "auto",
        "alignValue": "center",
        "mergeValues": true,
        "rowHeight": 0.9
      },
      "targets": [
        {
          "expr": "cmping_probe_success{source=~\"$relay\", probe_type=\"self\"}",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "title": "Self-probe Median RTT — all relays",
      "description": "Median RTT per relay for self-probes. Lines are extended across probe interval gaps.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 0,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_rtt_median_seconds{source=~\"$relay\", probe_type=\"self\"}",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "title": "Self-probe RTT Stats — $relay",
      "description": "Median, p90, and standard deviation for the selected relay. Use the Relay filter to select a single relay.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 1,
            "drawStyle": "line",
            "gradientMode": "scheme",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "cmping_rtt_p90_seconds{source=~\"$relay\", probe_type=\"self\"}",
          "legendFormat": "p90 {{source}}"
        },
        {
          "expr": "cmping_rtt_median_seconds{source=~\"$relay\", probe_type=\"self\"}",
          "legendFormat": "median {{source}}"
        },
        {
          "expr": "cmping_rtt_stddev_seconds{source=~\"$relay\", probe_type=\"self\"}",
          "legendFormat": "stddev {{source}}"
        }
      ]
    },
    {
      "title": "Account Setup Time",
      "description": "Time spent creating accounts on each relay. High on first run, near-zero on subsequent runs once accounts are cached.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "drawStyle": "line",
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "cmping_account_setup_seconds{source=~\"$relay\", probe_type=\"self\"}",
          "legendFormat": "{{source}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
